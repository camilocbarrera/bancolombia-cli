{
  "name": "bancolombia-cli",
  "version": "0.0.1",
  "description": "Manage your Bancolombia accounts via terminal, REST API, or MCP server for Claude",
  "author": "Cristian Correa",
  "license": "MIT",
  "keywords": [
    "bancolombia",
    "cli",
    "banking",
    "open-finance",
    "mcp",
    "claude",
    "hono",
    "bun",
    "colombia"
  ],
  "bin": {
    "bancolombia": "index.ts"
  },
  "module": "index.ts",
  "type": "module",
  "files": [
    "index.ts",
    "server.ts",
    "src/**/*.ts",
    "README.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "login": "bun run src/commands/login.ts",
    "connect": "bun run src/commands/connect.ts",
    "logout": "bun run src/commands/logout.ts",
    "accounts": "bun run src/commands/accounts.ts",
    "balance": "bun run src/commands/balance.ts",
    "transactions": "bun run src/commands/transactions.ts",
    "whoami": "bun run src/commands/whoami.ts",
    "health": "bun run src/commands/health.ts",
    "server": "bun run server.ts",
    "mcp": "bun run src/mcp/index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "optionalDependencies": {
    "playwright": "^1.58.2"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "hono": "^4.12.9",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  }
}
